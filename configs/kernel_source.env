# 内核源码信息
KERNEL_REPO="https://github.com/LineageOS/android_kernel_oneplus_sm8250.git"
KERNEL_BRANCH="lineage-23.2"

# arch/arm64/configs/ 下的 defconfig(相对路径,不带 arch/arm64/configs/ 前缀)
KERNEL_DEFCONFIG="vendor/kona-perf_defconfig"
KERNEL_DEFCONFIG_FRAGMENTS="vendor/debugfs.config"

KERNEL_ARCH="arm64"